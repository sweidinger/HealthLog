// ─── Audit Log ─────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  action    String // e.g. "auth.login", "measurement.create", "export.csv"
  details   String? // JSON string, no sensitive data
  ipAddress String?  @map("ip_address")
  location  String? // e.g. "Berlin, DE" — resolved from IP at log time
  // v1.4.27 B3 — resolved at audit-creation time from the bundled
  // GeoLite2-ASN MMDB. `asn` is the autonomous-system number,
  // `carrier` is the organisation string (e.g. "Deutsche Telekom AG").
  // Both nullable so older rows, private-IP rows, and offline-miss
  // rows stay valid.
  asn       Int? // autonomous-system number
  carrier   String? // autonomous-system organisation
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  // v1.12.1 (P1-2) — status-cache reads filter `{ userId, action }`
  // ordered by `createdAt desc` on every insight-status card mount;
  // this three-column index serves both the findFirst and the take:5 as
  // an index range scan over the highest-churn table. See migration 0123.
  @@index([userId, action, createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ─── Notification System ──────────────────────────────────────

model NotificationChannel {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String // "TELEGRAM" | "NTFY" | "WEB_PUSH" | "APNS"
  enabled   Boolean  @default(true)
  config    String // AES-256-GCM encrypted JSON (channel-specific config)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ── v1.4.15 Phase B3: reliability fields ─────────────────────
  // Reason the channel was auto-disabled (e.g. "hard_reject_410",
  // "telegram_blocked_by_user", "telegram_chat_not_found",
  // "give_up_after_5_failures"). NULL when the channel is healthy
  // OR was disabled manually (in which case `enabled=false` alone
  // is enough — no automated process should treat that as
  // re-enable-able).
  disabledReason      String?   @map("disabled_reason")
  consecutiveFailures Int       @default(0) @map("consecutive_failures")
  lastSuccessAt       DateTime? @map("last_success_at")
  lastFailureAt       DateTime? @map("last_failure_at")
  lastFailureReason   String?   @map("last_failure_reason")
  // The next time the dispatcher is allowed to attempt a send for
  // this channel after a transient failure. NULL = no cooldown.
  // Hard rejects flip `enabled=false` instead of writing this.
  nextRetryAt         DateTime? @map("next_retry_at")

  user        User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferences NotificationPreference[]

  @@unique([userId, type])
  @@index([userId])
  @@map("notification_channels")
}

model NotificationPreference {
  id        String  @id @default(cuid())
  channelId String  @map("channel_id")
  eventType String  @map("event_type") // "MEDICATION_REMINDER" | "MEASUREMENT_ANOMALY" | etc.
  enabled   Boolean @default(true)

  channel NotificationChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, eventType])
  @@map("notification_preferences")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String
  p256dh    String // encrypted
  auth      String // encrypted
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
  @@map("push_subscriptions")
}

// ─── Data Backups ────────────────────────────────────────────

model DataBackup {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String   @default("WEEKLY_AUTO") // WEEKLY_AUTO, MANUAL
  data      String // JSON export blob
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type], map: "data_backups_user_id_type_key")
  @@index([userId])
  @@map("data_backups")
}

// ─── Apple Health export.zip import (v1.4.34) ───────────────
//
// Mirrors a `pg-boss` `apple-health-import` job's lifecycle so the
// polling endpoint can read live per-phase progress without
// round-tripping through pg-boss internals (`output` only populates
// on completion in v12). The `pgBossJobId` link lets the worker
// reconcile a row by the boss id it just received from `boss.send`.
//
// Status state machine:
//   queued → unpacking → parsing → upserting → done
//                                            ↘  failed
//
// `progress` carries the live snapshot the worker writes every
// 1 000 records (see `ImportJobProgress` in
// `src/lib/measurements/import-apple-health-export.ts`). `result`
// carries the terminal `ImportJobResult` envelope.
model ImportJob {
  id                 String    @id @default(cuid())
  userId             String    @map("user_id")
  /// Admin who triggered the import on behalf of `userId` (admin
  /// variant only). NULL when the user kicked off their own import.
  triggeredByAdminId String?   @map("triggered_by_admin_id")
  /// `pg-boss` job id assigned by `boss.send`. Allows the worker to
  /// look up its mirror row by the boss id rather than passing the
  /// HealthLog id through the payload.
  pgBossJobId        String?   @unique @map("pg_boss_job_id")
  /// `queued | unpacking | parsing | upserting | done | failed`.
  status             String    @default("queued")
  /// Free-text reason on `failed`; null otherwise.
  failureReason      String?   @map("failure_reason")
  /// Bytes uploaded — surfaced to the operator audit trail.
  uploadBytes        Int       @map("upload_bytes")
  /// SHA-256 hex digest of the uploaded `export.zip`. Lets the
  /// kick-off endpoint short-circuit a re-upload of the exact same
  /// file back to the existing job id without re-queueing.
  uploadSha256       String?   @map("upload_sha256")
  /// Apple's `ExportDate` attribute string-formatted, parsed during
  /// the unpack phase. NULL until the parser sees it.
  exportedAt         DateTime? @map("exported_at")
  startedAt          DateTime  @default(now()) @map("started_at")
  completedAt        DateTime? @map("completed_at")
  /// JSON envelope mirroring `ImportJobProgress` (`src/lib/measurements/
  /// import-apple-health-export.ts`). Updated mid-run.
  progress           Json      @default("{}")
  /// JSON envelope mirroring `ImportJobResult`. NULL until terminal
  /// state. Carries per-type counts, workout counts, clinical /
  /// deferred / unknown buckets.
  result             Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@index([status])
  @@map("import_jobs")
}

// ─── Rate Limiting ──────────────────────────────────────────

model RateLimit {
  key     String   @id
  count   Int      @default(1)
  resetAt DateTime @map("reset_at")

  @@index([resetAt])
  @@map("rate_limits")
}

/// v1.11.0 W1 — durable, multi-instance provider-health ledger.
///
/// Promotes the volatile per-worker `lastWorkingCache`
/// (`provider-runner.ts`) to Postgres, modelled on the atomic-upsert
/// rate-limiter pattern so every worker shares one signal. One row per
/// (user, providerType): the runner records each outcome and reads the
/// row to (a) deprioritise / skip a provider inside its backoff window
/// instead of re-burning a dead round-trip every call, and (b) hold a
/// durable negative-cache for an auth-class failure (401/403 =
/// credential dead) far longer than the old 1h in-memory TTL, surfacing
/// it rather than silently retrying.
///
/// `nextRetryAt` is the backoff gate: while `lastResult = "auth_failed"`
/// and NOW() < `nextRetryAt`, the provider is skipped (negative cache).
/// On a success the row clears to `ok` with a null `nextRetryAt`.
/// Server-internal: never a Measurement, never ingested from a client.
model ProviderHealth {
  id                  String    @id @default(cuid())
  userId              String    @map("user_id")
  providerType        String    @map("provider_type") // ProviderChainType tag
  lastResult          String    @map("last_result") // "ok" | "hard_failed" | "auth_failed"
  lastStatus          Int?      @map("last_status") // HTTP status of the last failure; null on ok/network
  consecutiveFailures Int       @default(0) @map("consecutive_failures")
  lastOkAt            DateTime? @map("last_ok_at")
  lastFailureAt       DateTime? @map("last_failure_at")
  nextRetryAt         DateTime? @map("next_retry_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, providerType])
  @@index([userId, lastResult])
  @@map("provider_health")
}

// ─── Idempotency Keys (mobile-client replay protection) ──

/// Caches the response of a POST/PUT/PATCH/DELETE request keyed by
/// (userId, key, method, path) so retries within the TTL replay the
/// original outcome instead of producing a duplicate side-effect.
model IdempotencyKey {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  key            String
  method         String
  path           String
  responseStatus Int      @map("response_status")
  responseBody   String   @map("response_body") // serialized JSON envelope
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key, method, path])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

// ─── Devices (APNs / mobile push targets) ────────────────

/// Registered native-client device for push delivery. Token is unique
/// across users; re-registering on a different account is rejected with
/// 409 by `POST /api/devices` (cross-user-hijack guard).
///
/// `apnsToken` and `apnsEnvironment` are nullable because today's iOS
/// builds register through a generic `token` first; a follow-up call
/// from the iOS app populates the APNs-specific pair once the device
/// receives its first push token from `application:didRegisterForRemoteNotificationsWithDeviceToken:`.
/// Loose-typed `apnsEnvironment` (sandbox|production) leaves headroom
/// for whatever new gateway labels Apple ships next without a forced
/// migration.
model Device {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  platform        String // "ios"
  token           String   @unique
  bundleId        String   @map("bundle_id")
  locale          String?
  appVersion      String?  @map("app_version")
  model           String?
  apnsToken       String?  @map("apns_token")
  apnsEnvironment String?  @map("apns_environment") // "sandbox" | "production"
  /// v1.7.0 — per-device medication-delivery override. NULL = inherit the
  /// user-level roaming default
  /// (`User.notificationPrefs.medication.deliveryDefault`). "server"
  /// forces server APNs for this device; "client" forces local. Stored +
  /// echoed in v1.7.0; cron suppression stays user-level (APNs fans out to
  /// all the user's devices and iOS dedupes locally).
  medicationDelivery String? @map("medication_delivery")
  /// v1.17.1 (#22) — APNs push token for the iOS Live Activity update/end
  /// channel. ActivityKit issues a per-Activity push token distinct from the
  /// device APNs token; the server stores the most recent one so the worker
  /// can push a Live Activity content-state update or an end signal. NULL when
  /// the device has no active Live Activity. The iOS client owns the
  /// ActivityKit lifecycle and registers/clears this token; no server-side
  /// behaviour hangs off it beyond addressing the update push.
  liveActivityPushToken String? @map("live_activity_push_token")
  lastSeen        DateTime @default(now()) @map("last_seen")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  // `devices_apns_token_unique` is a partial UNIQUE index over
  // `apns_token IS NOT NULL` — see migration 0041. Prisma can't express
  // a partial index in the schema language, so it's introduced via raw
  // SQL and intentionally omitted here. Do not re-add `@@index([apnsToken])`
  // (the non-unique sibling) — the partial unique index supersedes it.
  @@map("devices")
}

// ─── Measurement / Vorsorge reminders ────────────────────────

/// v1.17.1 — preventive-care ("Vorsorge") reminders: "measure BP every 7
/// days", "annual blood panel", "log weight weekly". Reuses the existing
/// medication-reminder cadence vocabulary (`intervalDays` rolling cadence OR
/// an RFC-5545 `rrule`) so the recurrence engine drives the due-date math, and
/// rides the existing notification dispatcher + `push_attempts` ledger. The
/// completion target is either a `measurementType` (auto-resolved when a
/// matching measurement lands) or a free-text `label` for non-measurement
/// Vorsorge that only resolves on a manual check-off. `nextDueAt` is
/// server-computed + stored (server-authoritative — iOS consumes the resolved
/// value, never recomputes). Soft-deleted.
model MeasurementReminder {
  id              String           @id @default(cuid())
  userId          String           @map("user_id")
  /// User-facing copy: "Blutdruck messen", "Großes Blutbild".
  label           String
  /// Auto-resolve target. NULL = free-text / checklist Vorsorge (a blood
  /// panel, a dermatology check) with no measurement to match against; those
  /// resolve only on a manual satisfy. Non-NULL = the cron advances
  /// `lastSatisfiedAt` when a matching Measurement of this type lands.
  measurementType MeasurementType? @map("measurement_type")
  /// Rolling cadence: fire every N days (7 / 30 / 365). Maps to the recurrence
  /// engine's `rollingIntervalDays`. Mutually exclusive with `rrule` in
  /// practice; both NULL is a one-shot reminder anchored on `anchorDate`.
  intervalDays    Int?             @map("interval_days")
  /// Optional RFC-5545 recurrence (e.g. `FREQ=YEARLY`). Maps straight through
  /// the same recurrence engine the medication schedules use.
  rrule           String?
  /// First-due anchor; the resolver falls back to `lastSatisfiedAt ?? createdAt`
  /// when NULL.
  anchorDate      DateTime?        @map("anchor_date")
  /// Optional course-window end. NULL = open-ended cadence (the existing
  /// behaviour). Non-NULL bounds a finite cadence: the recurrence engine
  /// (`medication.endsOn` precedent) stops producing occurrences past this
  /// instant, so a Coach-suggested "measure BP morning+evening for a week"
  /// self-expires. Additive; every existing reminder keeps `NULL` and stays
  /// open-ended.
  endsOn          DateTime?        @map("ends_on")
  /// Who produced this reminder. `VORSORGE` = the user created it through the
  /// Vorsorge surface (the existing, default behaviour). `COACH` = the AI
  /// coach minted it from an evidence-based cadence suggestion, posted to the
  /// SAME `POST /api/measurement-reminders` endpoint — one engine, not two.
  /// Lets the UI label provenance and lets Coach dedupe its own suggestions.
  origin          ReminderOrigin   @default(VORSORGE)
  /// Local hour (0–23) to fire the nudge, mirroring the mood-reminder hour.
  /// DST-safe windowing is applied at the cron via the existing TZ helpers.
  notifyHour      Int              @default(9) @map("notify_hour")
  /// Free-text "wo": "Hausarzt", "Labor Dr. X". Optional.
  location        String?
  /// Server-computed canonical next-due instant (server-authoritative).
  nextDueAt       DateTime?        @map("next_due_at")
  /// When the reminder was last fulfilled (a matching measurement or a manual
  /// satisfy). Re-anchors the next-due computation.
  lastSatisfiedAt DateTime?        @map("last_satisfied_at")
  /// Master on/off for this reminder. Distinct from soft-delete: a disabled
  /// reminder is retained + editable but never fires.
  enabled         Boolean          @default(true)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  /// Soft-delete tombstone. NULL = live; non-NULL = deleted at the instant.
  deletedAt       DateTime?        @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, deletedAt])
  @@index([userId, nextDueAt])
  // v1.18.1 — structural accept-dedup for COACH-minted reminders: at most
  // one LIVE COACH reminder per (user, metric). Enforced as a PARTIAL unique
  // index (`WHERE origin = 'COACH' AND deleted_at IS NULL`) created by the
  // 0172 migration — Prisma's schema DSL cannot express a filtered unique
  // index, so the migration owns the constraint and this is a pointer to it.
  @@map("measurement_reminders")
}

/// Provenance of a MeasurementReminder. `VORSORGE` = user-created through the
/// Vorsorge surface (default); `COACH` = minted by the AI coach from a cadence
/// suggestion. Both feed the same engine / endpoint / cron.
enum ReminderOrigin {
  VORSORGE
  COACH

  @@map("reminder_origin")
}

// ─── Lab results ─────────────────────────────────────────────

/// v1.17.1 — minimal structured lab store pairing with the Vorsorge "annual
/// blood panel" reminder. HealthLog has no first-class blood-biomarker type
/// beyond glucose, so a self-hoster who gets a panel back had nowhere to record
/// LDL / HbA1c / ferritin / TSH. This is the lean storage row: one analyte per
/// row, optional panel grouping, optional reference range. The doctor-report /
/// charting wiring lands in sibling work — this model only owns the shape.
/// Soft-deleted.
model LabResult {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  /// Optional grouping label, e.g. "Großes Blutbild". NULL = standalone value.
  panel         String?
  /// The biomarker name, e.g. "LDL", "HbA1c", "Ferritin".
  analyte       String
  value         Float
  unit          String
  /// Optional reference-range bounds as reported by the lab.
  referenceLow  Float?    @map("reference_low")
  referenceHigh Float?    @map("reference_high")
  /// When the sample was taken (UTC instant; wall-clock anchoring is the
  /// reader's concern per the schema's UTC-only convention).
  takenAt       DateTime  @map("taken_at")
  /// v1.19.0 — optional link to the user-scoped Biomarker catalog. NULL on
  /// every existing row; a backfill job grouping by `lower(analyte)` will
  /// populate it later (this migration only adds the column + relation). Once
  /// linked, server reads resolve the canonical unit + reference bounds from
  /// the Biomarker, ending the per-row free-text divergence ("LDL" vs "ldl"
  /// vs "LDL-C", `mg/dL` vs `mg/dl`). The legacy `analyte` / `unit` /
  /// `reference*` columns stay as historical truth for one release.
  biomarkerId   String?    @map("biomarker_id")
  /// Provenance: "MANUAL" today; import paths set their own source string.
  source        String    @default("MANUAL")
  /// Optional free-text note, AES-256-GCM encrypted at rest via
  /// `src/lib/crypto.ts` (Bytes column, `*Encrypted` suffix per convention).
  noteEncrypted Bytes?    @map("note_encrypted")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  /// Soft-delete tombstone. NULL = live; non-NULL = deleted at the instant.
  deletedAt     DateTime? @map("deleted_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  biomarker Biomarker? @relation(fields: [biomarkerId], references: [id], onDelete: SetNull)

  @@index([userId, analyte, takenAt])
  @@index([userId, deletedAt])
  @@index([biomarkerId])
  @@map("lab_results")
}

// ─── Biomarker catalog ───────────────────────────────────────

/// v1.19.0 — user-scoped catalog of blood/lab biomarkers. Defining a marker
/// once (canonical name, unit, reference bounds, optional context note) and
/// recording LabResult values against it ends the per-row free-text
/// divergence the lean v1.17.1 LabResult model invites (re-typing analyte /
/// unit / both bounds on every reading). The reference range + unit are
/// authoritative on the catalog row, not on the entry; server reads resolve
/// from here and the resolved values flow into the DTO (iOS renders, never
/// recomputes). Unique per user + name so there is never two "LDL"
/// definitions.
model Biomarker {
  id         String  @id @default(cuid())
  userId     String  @map("user_id")
  /// Canonical display name, e.g. "LDL Cholesterol".
  name       String
  /// Canonical unit for every reading against this marker, e.g. "mg/dL".
  unit       String
  /// Optional reference-range bounds. The lab/sex/age-dependent "normal"
  /// window; the server's range verdict is computed against these.
  lowerBound Float?  @map("lower_bound")
  upperBound Float?  @map("upper_bound")
  /// Optional per-marker context ("what this means"), AES-256-GCM encrypted
  /// at rest via `src/lib/crypto.ts` (Bytes column, `*Encrypted` suffix per
  /// convention).
  contextEncrypted Bytes? @map("context_encrypted")
  /// Optional panel grouping moved off the per-entry row, e.g.
  /// "Großes Blutbild". NULL = standalone marker.
  panel     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  results LabResult[]

  @@unique([userId, name])
  @@index([userId])
  @@map("biomarkers")
}

// ─── User Achievements ───────────────────────────────────────

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  achievementId String   @map("achievement_id")
  unlockedAt    DateTime @map("unlocked_at")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

// ─── Host Metrics (admin system-status host-load chart) ──────

/// Per-minute snapshot of host-process load + memory captured by the
/// pg-boss `host-metric-sample` job. Read by `/api/admin/host-metrics`
/// to render the host-load trend above the system-status section.
/// 7-day retention is enforced inside the sampler — we keep the table
/// small enough that a single `findMany` over the last 2 hours stays
/// well under 200 rows.
model HostMetric {
  id             String   @id @default(cuid())
  capturedAt     DateTime @default(now()) @map("captured_at")
  loadAvg1       Float    @map("load_avg_1")
  loadAvg5       Float    @map("load_avg_5")
  loadAvg15      Float    @map("load_avg_15")
  memUsedBytes   BigInt   @map("mem_used_bytes")
  memTotalBytes  BigInt   @map("mem_total_bytes")
  // Optional rolling-window byte counters from /proc/diskstats. Null
  // outside Linux (macOS dev machines, Windows). The API endpoint
  // converts deltas into bytes-per-second client-side.
  diskReadBytes  BigInt?  @map("disk_read_bytes")
  diskWriteBytes BigInt?  @map("disk_write_bytes")

  @@index([capturedAt])
  @@map("host_metrics")
}

// ─── Recommendation Feedback (v1.4.16 phase B5e) ───────────────
//
// Per-recommendation thumbs-up / thumbs-down rating. Captured client-
// side under each rec card; persisted with provider attribution
// (providerType + promptVersion) so the daily aggregator can slice
// helpful-rate per (severity x provider x prompt) for the admin AI
// quality dashboard.
//
// Default-on for the single-user case (only the user's ratings shape
// the user's future prompts); cross-user aggregate stays admin-only
// (no prompt-tuning flow yet — that ratchet is v1.4.17).
//
// Privacy: server-side fills providerType + promptVersion from the
// user's most recent cached payload (User.insightsCachedText) so the
// client can't tamper with the attribution.
//
// `(userId, recommendationId, recommendationText)` is the dedup key.
// recommendationText snapshots the rec at submission time so a re-
// generation that rewrites the same id with new text counts as a
// different row — that's intentional, the aggregator wants per-text
// signal not per-id signal.
model RecommendationFeedback {
  id                     String   @id @default(cuid())
  userId                 String   @map("user_id")
  recommendationId       String   @map("recommendation_id")
  // Nullable since v1.4.23 reconcile (Sr-H3): the recommendation
  // surface still snapshots the prose here (recommendations are
  // unencrypted on the wire, so plaintext is the source-of-truth);
  // the Coach surface leaves it NULL and references the message via
  // `coachMessageId` so the assistant prose stays encrypted-at-rest
  // in `coach_messages.encryptedContent`.
  recommendationText     String?  @map("recommendation_text")
  recommendationSeverity String   @map("recommendation_severity")
  metricSourceType       String   @map("metric_source_type")
  metricSourceTimeRange  String   @map("metric_source_time_range")
  helpful                Boolean
  providerType           String   @map("provider_type")
  promptVersion          String   @map("prompt_version")
  createdAt              DateTime @default(now()) @map("created_at")

  // v1.4.23 H7 — polymorphic target so Coach replies share the table.
  // "recommendation" (default) is the v1.4.16 B5e shape; "coach" is a
  // Coach assistant message. The aggregator slices on targetType to
  // bucket each surface independently. Default value lets every
  // pre-v1.4.23 row read as "recommendation" without a backfill.
  targetType String  @default("recommendation") @map("target_type")
  // Optional free-form reason — populated when the user clicks
  // "unhelpful" and selects a category from the small chip strip.
  // Capped at 200 chars upstream so the table can't bloat from a
  // pasted essay.
  reason     String? @map("reason")

  // v1.4.23 reconcile (Sr-H3) — Coach surface references the source
  // message instead of snapshotting its prose into
  // `recommendationText`. FK + cascade so a deleted message drops the
  // rating row too. Always NULL for `targetType="recommendation"`.
  coachMessageId String?       @map("coach_message_id")
  coachMessage   CoachMessage? @relation(fields: [coachMessageId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, recommendationId, recommendationText], map: "rec_feedback_user_rec_text_key")
  @@index([userId, createdAt])
  @@index([recommendationSeverity, helpful, createdAt])
  @@index([targetType, createdAt])
  @@index([coachMessageId])
  @@map("recommendation_feedback")
}

// ─── AI Coach (v1.4.20) ────────────────────────────────────
//
// Conversation thread between a user and the AI Coach. Messages are
// stored encrypted at rest via AES-256-GCM (`src/lib/crypto.ts`) under
// the active `ENCRYPTION_KEYS` entry — the Coach inherits the same
// key-rotation tooling as the rest of the app. GDPR cascade through
// User keeps the model deletion-clean.
//
// `title` is a short snippet of the first user message (≤80 chars,
// non-encrypted) so the history rail can render without paying the
// per-message decrypt cost. The snippet is plain text; do not put PII
// the user explicitly opted out of into it. The summarisation helper
// in `src/lib/ai/coach/persistence.ts` truncates with an ellipsis.
model CoachConversation {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // v1.11.0 — rolling encrypted summary of the elided older turns, so a long
  // conversation keeps memory of what came before without re-sending every
  // turn to the provider. AES-256-GCM (same codec as CoachMessage.encrypted).
  summaryEncrypted Bytes?    @map("summary_encrypted")
  summaryUpdatedAt DateTime? @map("summary_updated_at")
  summaryTurnCount Int       @default(0) @map("summary_turn_count")

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages CoachMessage[]

  @@index([userId, updatedAt])
  @@map("coach_conversations")
}

// One message in a Coach conversation. `role` is "user" or "assistant"
// — same shape as the OpenAI/Anthropic chat-completion APIs.
//
// `encryptedContent` holds the AES-256-GCM ciphertext of the message
// body. The encrypt/decrypt helpers stamp the active key id into the
// ciphertext so rotation works without a backfill.
//
// `metricSourceJson` is the provenance envelope ("based on 14d HRV +
// 6 BP readings") attached to assistant messages — labels only, NEVER
// raw values. The frontend renders source-chip rows from this field.
// It is intentionally NOT encrypted: the labels are window+metric
// names ("last30days", "bloodPressure", "n=12") and carry no PII; the
// stable shape lets future analytics queries slice without a key.
//
// `providerType` and `promptVersion` mirror the recommendation-
// feedback attribution columns so the cross-feature aggregator can
// slice helpful-rate per (provider × prompt) for Coach replies too.
model CoachMessage {
  id               String   @id @default(cuid())
  conversationId   String   @map("conversation_id")
  role             String // "user" | "assistant"
  encryptedContent Bytes    @map("encrypted_content")
  metricSourceJson String?  @map("metric_source_json")
  providerType     String?  @map("provider_type")
  promptVersion    String?  @map("prompt_version")
  createdAt        DateTime @default(now()) @map("created_at")

  conversation CoachConversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  // v1.4.23 reconcile (Sr-H3) — back-relation for the FK that lets
  // Coach feedback rows reference their source message instead of
  // snapshotting plaintext prose into `recommendation_feedback`.
  feedback     RecommendationFeedback[]

  @@index([conversationId, createdAt])
  // v1.18.6 (L1) — the FAB nudge-status poll and the cron's persisted-nudge
  // frequency gate both scan a user's assistant messages newest-first
  // (optionally filtered to provider_type = 'nudge'). This index lets the
  // planner do an index-backed per-conversation merge instead of gathering +
  // sorting every assistant row in the user's threads on each global poll.
  @@index([conversationId, role, createdAt(sort: Desc)])
  @@map("coach_messages")
}

// v1.11.1 (Epic B, B-W7) — durable, user-scoped personal facts the Coach
// extracts from conversations: stable preferences, conditions the user states
// about themselves, goals, constraints, durable life context. The fact TEXT is
// encrypted at rest (AES-256-GCM, the same codec as CoachMessage). `category`,
// `confidence`, and `sourceConversationId` stay plain so the injection picker
// can rank without paying a per-row decrypt. Descriptive, never diagnostic.
// Soft-delete via `deletedAt` so a user "forget this" action is reversible /
// auditable and re-extraction can avoid resurrecting it.
model CoachFact {
  id                   String    @id @default(cuid())
  userId               String    @map("user_id")
  factEncrypted        Bytes     @map("fact_encrypted")
  // App-side closed enum (not a DB enum, to keep the migration purely additive
  // and avoid an enum-migration per new category): preference | condition |
  // goal | constraint | context.
  category             String
  // 0..100 server-assigned extraction confidence.
  confidence           Int       @default(50)
  // Provenance — nullable so a future manual-entry surface can leave it null.
  sourceConversationId String?   @map("source_conversation_id")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  // Soft-delete: hides the fact from injection but keeps the row for audit.
  deletedAt            DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, deletedAt, confidence])
  @@map("coach_facts")
}

// v1.15.20 — user-authored "about me" self-description the AI surfaces
// (Coach system prompt + daily-briefing user prompt) inject as a clearly
// delimited, user-provided context block. 1:1 with User and lazily
// created on first save so existing accounts pay nothing. The free text
// is encrypted at rest (AES-256-GCM via the shared Bytes codec, exactly
// like `CoachFact.factEncrypted`) — it is unstructured health prose and
// must never land in the table as plaintext. A cleared profile keeps the
// row with a NULL payload so `updatedAt` documents the deletion instant.
model UserHealthProfile {
  id               String   @id @default(cuid())
  userId           String   @unique @map("user_id")
  // Free text, hard-capped at 4 000 chars by the route's Zod schema
  // BEFORE encryption. NULL = cleared / never written.
  aboutMeEncrypted Bytes?   @map("about_me_encrypted")
  // v1.16.0 — structured self-context companions to the free text.
  // Short answers (each capped at 500 chars BEFORE encryption).
  // Age/gender deliberately do NOT live here — they come from the User
  // profile and are merged into the prompt block at assembly time so
  // the data is never duplicated.
  conditionsEncrypted Bytes? @map("conditions_encrypted")
  allergiesEncrypted  Bytes? @map("allergies_encrypted")
  coachFocusEncrypted Bytes? @map("coach_focus_encrypted")
  // v1.16.0 — up to 3 clarifying questions the server derives after a
  // save (AI-generated when a provider + budget allow, deterministic
  // hints otherwise). Encrypted JSON string[]; the Coach composer
  // renders them as tappable suggestion chips. NULL = none pending.
  pendingQuestionsEncrypted Bytes? @map("pending_questions_encrypted")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_health_profiles")
}

// Per-user, per-day token-spend ledger for the AI Coach. The dispatcher
// reads `totalTokens` against `MAX_TOKENS_PER_USER_PER_DAY` before
// hitting any provider, so a runaway client cannot drain the operator's
// LLM budget. `dateKey` is the UTC `YYYY-MM-DD` bucket; the unique
// constraint enforces one row per (user, day). `messageCount` is a
// secondary signal used by the frontend to render a "≈ N replies left"
// hint without exposing raw token figures.
model CoachUsage {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  dateKey      String   @map("date_key")
  totalTokens  Int      @default(0) @map("total_tokens")
  messageCount Int      @default(0) @map("message_count")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
  @@index([userId, dateKey])
  @@map("coach_usage")
}

// ─── Consent Receipts (v1.4.40 SB-10) ─────────────────────────
//
// Per-user audit trail of AI-processing consent grants. The iOS app
// posts a fresh row whenever the user opts in to off-device AI flows
// during onboarding or via Settings; append-only so a revoke + re-grant
// cycle reads chronologically. Persists the raw signed artefact (PDF
// receipt OR signed JWT — caller's choice) the App-Store Guideline
// 5.1.2(i) audit needs to be verifiable. The latest row per user is
// the source of truth for "is AI active right now" decisions; older
// rows are kept for the GDPR Art. 7 burden of proof.
//
// `kind` is a free-text discriminator the iOS / web client uses to
// distinguish "ai_full" / "ai_insights_only" / future scopes without
// requiring a schema migration per new tier.
model ConsentReceipt {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  kind      String
  /// Raw consent artefact — either a base64-encoded PDF or a signed
  /// JWT. The server does not parse this payload; the audit trail is
  /// the storage itself plus the `signedAt` timestamp.
  artefact  String    @db.Text
  /// Wall-clock the client recorded the user's tap. UTC ISO-8601.
  signedAt  DateTime  @map("signed_at")
  /// Optional revocation marker — set when a follow-up "revoke" row
  /// is minted so the latest-per-user lookup can shortcut to "no
  /// active consent" without diffing the kind discriminator.
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  // `consent_receipts_user_id_kind_active_key` is a partial UNIQUE index
  // over (user_id, kind) `WHERE revoked_at IS NULL` — see migration 0159.
  // It enforces at most one *active* receipt per (user, kind) so two
  // concurrent web-grant heals can't both mint an active row. Prisma can't
  // express a partial-predicate unique in the schema language, so it's
  // introduced via raw SQL and intentionally omitted here. The append-only
  // history (revoked rows) stays unconstrained because revoked rows carry a
  // non-NULL `revoked_at` and fall outside the predicate.
  @@map("consent_receipts")
}

// ─── Push attempt ledger (v1.4.49) ───────────────────────────
//
// Per-attempt push-delivery history. Every sender on the dispatcher
// cascade (APNS, WEB_PUSH, TELEGRAM, NTFY) writes one fire-and-forget
// row per dispatch so the admin diagnostic endpoint can surface the
// trailing 20 attempts per user without needing DB shell access.
//
// The write is best-effort: a DB hiccup on the insert must not break
// the actual push delivery, so every sender wraps the `create()` in a
// `void … .catch(() => {})` block. There is no retry — a single
// missing row is acceptable.
//
// Retention: a daily cron at 03:35 Europe/Berlin (between the
// audit-log cleanup at 03:15 and the mood-reminder cleanup at 03:25)
// deletes rows older than 90 days. See `handlePushAttemptCleanup` in
// `src/lib/jobs/reminder-worker.ts`.
//
// `eventType` mirrors the dispatcher's `NotificationPayload.eventType`
// string (`MEDICATION_REMINDER`, `MOOD_REMINDER`, `PERSONAL_RECORD`,
// `MEASUREMENT_ANOMALY`, `SYSTEM_ALERT`, …); stored as plain text so
// future event-type additions never require a schema migration.
//
// `channel` is the dispatcher `ChannelType` string (`APNS`,
// `WEB_PUSH`, `TELEGRAM`, `NTFY`).
//
// `result` is one of `"ok"` | `"error"` | `"skipped"` — `skipped`
// covers the "no recipient" / "config missing" soft cases.
//
// `reason` is the failure reason on `error` or `skipped` results, and
// null on `ok`. For APNS this is Apple's reason code
// (`BadDeviceToken`, `Unregistered`, …); for Web Push it carries the
// classified `web_push_*` reason; Telegram / NTFY likewise mirror
// their sender-side `SendOutcome.reason`.
model PushAttempt {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  channel   String // "APNS" | "WEB_PUSH" | "TELEGRAM" | "NTFY"
  eventType String   @map("event_type") // dispatcher event-type string
  result    String // "ok" | "error" | "skipped"
  reason    String? // sender-side reason on error/skip; null on ok
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("push_attempts")
}

// ─── Clinician share links (scoped, time-limited, revocable read view) ───
//
// v1.11.0 — a user mints a link they hand a clinician (email, paper, QR).
// The clinician opens it in any browser with no account and sees a
// read-only view of the health record. The raw `hls_` token is stored
// ONLY as an HMAC-SHA256 hash (`tokenHash`, same scheme as
// `ApiToken.tokenHash`, keyed by `API_TOKEN_HMAC_KEY`); the plaintext is
// returned to the owner exactly once at creation and never persisted.
//
// The scope is FROZEN at creation: `rangeStart`, `sectionsJson` and
// `resourceTypes` are write-once and a share can NEVER widen later — only
// `revokedAt`, `lastAccessAt` and `accessCount` mutate after mint. This
// mirrors the append-only spirit of `ConsentReceipt`. `expiresAt` is
// mandatory (capped at `SHARE_LINK_MAX_DAYS`, default 90) — there is no
// never-expiring share. Deleting the user cascades every share away so
// the GDPR-erasure path stays clean.
model ClinicianShareLink {
  id        String @id @default(cuid())
  userId    String @map("user_id")
  /// HMAC-SHA256 of the raw `hls_` token (same scheme as `ApiToken.tokenHash`).
  tokenHash String @unique @map("token_hash")
  /// Human label the owner sets (e.g. a clinic/specialty note). Plaintext, bounded.
  label     String

  // ── Frozen scope (write-once at creation; never widened) ──
  /// Reporting-window start (absolute, not "last N days"). Frozen so a
  /// rolling share can never reach data older than the owner chose.
  rangeStart   DateTime @map("range_start")
  /// Window end. Null = rolling ("up to now"); set = frozen snapshot window.
  rangeEnd     DateTime? @map("range_end")
  /// Section toggles (the `DoctorReportPrefs` shape the export uses). JSON.
  sectionsJson Json @map("sections_json")
  /// FHIR resource types this link may serve (a subset of the catalogue),
  /// e.g. `["Observation","MedicationStatement"]`.
  resourceTypes String[] @map("resource_types")
  /// Whether the FHIR API is reachable via this link at all (vs the view only).
  allowFhirApi Boolean @default(false) @map("allow_fhir_api")

  /// REQUIRED — no never-expiring share (capped at `SHARE_LINK_MAX_DAYS`).
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // ── Mutable lifecycle/access counters (the only columns that change) ──
  revokedAt    DateTime? @map("revoked_at")
  lastAccessAt DateTime? @map("last_access_at")
  accessCount  Int       @default(0) @map("access_count")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("clinician_share_links")
}

// v1.11.0 W3 — period-narrative cache (Pillar P1).
//
// One durable, typed row per (user, period, locale) carrying the latest
// generated period summary ("how your week/month went"). Delete +
// regenerate clean: the unique constraint enforces a single row per slot,
// so a regeneration upserts in place and there is never a stale duplicate
// to disambiguate. The generated prose is held AES-256-GCM at rest in
// `encryptedContent` (Bytes), following the `CoachMessage.encryptedContent`
// precedent — the body is descriptive health narrative and is treated as
// sensitive even though it carries labels-plus-numbers, not raw rows.
//
// `provenanceJson` is the labels-only provenance envelope the surface
// renders as ⓘ chips (metric names + the read window + the FDR footer);
// it carries no PII so it stays plaintext for a stable, queryable shape,
// matching `CoachMessage.metricSourceJson`. `providerType` + `promptVersion`
// mirror the attribution columns so the cross-feature aggregator can slice
// quality per (provider × prompt). `period` is `week` | `month`; `dateKey`
// is the UTC `YYYY-MM-DD` boundary the row was generated for, so the
// stale-while-revalidate read can tell "today's" narrative from an older
// one without decrypting.
model InsightNarrative {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  /// "week" | "month".
  period           String
  /// Resolved UI locale of the prose ("de" | "en").
  locale           String
  /// UTC YYYY-MM-DD boundary the narrative was generated for.
  dateKey          String   @map("date_key")
  /// AES-256-GCM ciphertext of the generated narrative prose.
  encryptedContent Bytes    @map("encrypted_content")
  /// Labels-only provenance envelope (metric names, window, FDR footer).
  provenanceJson   String?  @map("provenance_json")
  providerType     String?  @map("provider_type")
  promptVersion    String?  @map("prompt_version")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One row per (user, period, locale) — regeneration upserts in place.
  @@unique([userId, period, locale])
  @@index([userId, updatedAt(sort: Desc)])
  @@map("insight_narratives")
}

// ─── Cycle Tracking (v1.15.0) ─────────────────────────────────
//
// Self-hosted reproductive-health tracking: period + flow, symptom
// taxonomy, BBT / OPK / cervical-mucus capture, ranged-confidence
// prediction. The capture rows (MenstrualCycle, CycleDayLog) carry the
// same soft-delete + syncVersion shape as MoodEntry so they ride the
// `/api/sync/changes` delta feed. CycleProfile + CyclePrediction are
// settings / derived rows and do NOT tombstone.
//
// Sensitivity: free-text notes are always AES-256-GCM at rest
// (`notesEncrypted`, the `*Encrypted` convention). The default-ON
// `sensitiveCategoryEncryption` flag drives whether the intent-revealing
// fields (pregnancy / contraception / sexual activity) also encrypt at
// the application layer — those stay queryable-plaintext-physiology
// (flow, BBT, OPK, mucus, dates, phase) untouched so the rollup +
// correlation tier keeps working.

/// Per-user goal that gates every cycle copy + the fertile-window
/// surfacing. `OFF` disables the category entirely; `GENERAL_HEALTH` /
/// `PERIMENOPAUSE` hide conception framing; only `TRYING_TO_CONCEIVE`
/// (and, with a stronger caveat, `AVOID_PREGNANCY`) surface fertile-window
/// language.
enum CycleTrackingGoal {
  GENERAL_HEALTH
  AVOID_PREGNANCY
  TRYING_TO_CONCEIVE
  PERIMENOPAUSE
  OFF

  @@map("cycle_tracking_goal")
}

/// Menstrual-flow intensity for a logged day. Mirrors the HealthKit
/// `HKCategoryValueMenstrualFlow` ladder (unspecified collapses to the
/// presence of a row; `NONE` is an explicit no-flow marker).
enum FlowLevel {
  NONE
  SPOTTING
  LIGHT
  MEDIUM
  HEAVY

  @@map("flow_level")
}

/// Ovulation predictor-kit (OPK) reading. `POSITIVE_LH_SURGE` is the
/// LH-surge positive; `ESTROGEN_SURGE` is the estrogen-rise pre-peak
/// some dual-hormone kits report. Mirrors HealthKit
/// `HKCategoryValueOvulationTestResult`.
enum OvulationTest {
  NEGATIVE
  POSITIVE_LH_SURGE
  ESTROGEN_SURGE
  INDETERMINATE

  @@map("ovulation_test")
}

/// Cervical-mucus quality, fertility-awareness ladder (dry → egg-white
/// peak). Mirrors HealthKit `HKCategoryValueCervicalMucusQuality`.
enum CervicalMucus {
  DRY
  STICKY
  CREAMY
  WATERY
  EGG_WHITE

  @@map("cervical_mucus")
}

/// Generic home-test result for the pregnancy / progesterone test
/// fields. Mirrors HealthKit `HKCategoryValuePregnancyTestResult` /
/// `HKCategoryValueProgesteroneTestResult`.
enum HomeTestResult {
  NEGATIVE
  POSITIVE
  INDETERMINATE

  @@map("home_test_result")
}

/// Contraceptive method logged for a day. `UNSPECIFIED` mirrors the
/// HealthKit `unspecified` member distinct from `NONE` (an explicit
/// no-method marker). Mirrors HealthKit `HKCategoryValueContraceptive`.
enum ContraceptiveKind {
  NONE
  UNSPECIFIED
  IMPLANT
  INJECTION
  IUD
  INTRAVAGINAL_RING
  ORAL
  PATCH
  EMERGENCY

  @@map("contraceptive_kind")
}

/// Derived cycle phase used by the prediction engine + the CYCLE_PHASE
/// correlation channel. Computed from day-of-cycle + the back-calculated
/// luteal length, never stored on the capture rows.
enum CyclePhase {
  MENSTRUAL
  FOLLICULAR
  OVULATORY
  LUTEAL

  @@map("cycle_phase")
}

/// Which symptothermal SECONDARY sign the user observes alongside the
/// temperature primary sign for the Sensiplan double-check. `MUCUS`
/// (cervical-mucus quality) is the default; `CERVIX` swaps in the cervix
/// observation (position / firmness / opening). The temperature primary
/// sign is unchanged either way — only the second indicator of the
/// double-check differs. Mirrors the `drip` app's Settings →
/// Customization → Secondary symptom choice.
enum SecondarySymptom {
  MUCUS
  CERVIX

  @@map("secondary_symptom")
}

/// Cervix vertical position, a Sensiplan cervix sign. Fertile = `HIGH`
/// (the cervix rises around ovulation); infertile = `LOW`.
enum CervixPosition {
  LOW
  HIGH

  @@map("cervix_position")
}

/// Cervix firmness, a Sensiplan cervix sign. Fertile = `SOFT` (the cervix
/// softens around ovulation); infertile = `FIRM`.
enum CervixFirmness {
  FIRM
  SOFT

  @@map("cervix_firmness")
}

/// Cervix os / opening, a Sensiplan cervix sign. Fertile = `OPEN`;
/// infertile = `CLOSED`.
enum CervixOpening {
  CLOSED
  OPEN

  @@map("cervix_opening")
}

/// Broad condition class for an IllnessEpisode (v1.19.0). Widened beyond an
/// infection log so the journal covers any condition the user keeps for
/// themselves.
enum IllnessType {
  INFECTION
  ALLERGY
  INJURY
  MENTAL_HEALTH
  AUTOIMMUNE
  CHRONIC
  OTHER

  @@map("illness_type")
}

/// Where an IllnessEpisode sits in its lifecycle (v1.19.0). `CHRONIC_ONGOING`
/// has no "recovered" date and is excluded from the recovery-gap math;
/// `FLARE` rows hang off a parent condition via `parentConditionId`.
enum IllnessLifecycle {
  ACUTE
  CHRONIC_ONGOING
  RECURRING
  FLARE

  @@map("illness_lifecycle")
}

/// Which method produced a cached CyclePrediction. `CALENDAR` is the
/// median+MAD variability predictor; `SYMPTOTHERMAL` folds the
/// sensiplan BBT + mucus confirmation; `TEMPERATURE_TREND` is the
/// retrospective wrist/skin-temperature ovulation; `BLENDED` combines
/// them.
enum PredictionMethod {
  CALENDAR
  SYMPTOTHERMAL
  TEMPERATURE_TREND
  BLENDED

  @@map("prediction_method")
}

/// One settings row per user, lazily upserted on first cycle-surface
/// access (goal defaults to GENERAL_HEALTH). Not soft-deleted — it is a
/// profile row, like the other per-user settings columns on User.
model CycleProfile {
  id     String @id @default(cuid())
  userId String @map("user_id")

  /// Drives all cycle copy + fertile-window gating (see CycleTrackingGoal).
  goal CycleTrackingGoal @default(GENERAL_HEALTH)

  /// Per-user feature enable. NULL = derive from gender (`FEMALE` → on,
  /// everything else → off) so the column never needs a backfill; an
  /// explicit `true` opts a non-FEMALE account in, an explicit `false`
  /// opts a FEMALE account out. Resolved through `isCycleEnabled()` —
  /// every `/api/cycle/*` route 403s with `errorCode:"cycle.disabled"`
  /// when the resolved value is false.
  cycleTrackingEnabled Boolean? @map("cycle_tracking_enabled")

  /// Optional user-supplied priors. The engine applies a luteal default
  /// of 14 days in code (NOT a DB default) when `lutealPhaseLength` is
  /// NULL, so a future constant change never strands historical rows.
  typicalCycleLength  Int? @map("typical_cycle_length")
  typicalPeriodLength Int? @map("typical_period_length")
  lutealPhaseLength   Int? @map("luteal_phase_length")

  /// Which symptothermal SECONDARY sign the user observes for the Sensiplan
  /// double-check: `MUCUS` (default) or `CERVIX`. Lives behind the advanced
  /// cycle settings — the casual user keeps temperature + mucus and never
  /// sees the choice. The temperature primary sign is unchanged either way.
  secondarySymptom SecondarySymptom @default(MUCUS) @map("secondary_symptom")

  /// When false, the app computes / stores NO predictions — pure logging
  /// (the Read-Your-Body posture for users who distrust algorithmic
  /// interpretation).
  predictionEnabled Boolean @default(true) @map("prediction_enabled")
  /// Raw-chart mode — surfaces logged values without the interpreted
  /// prediction overlays.
  rawChartMode      Boolean @default(false) @map("raw_chart_mode")

  /// When true, every cycle push body is generic ("HealthLog reminder")
  /// so no cycle-event naming reaches the lock screen.
  discreetNotifications        Boolean @default(false) @map("discreet_notifications")
  /// Default-ON for this category (post-Dobbs threat model): drives
  /// whether the intent-revealing day-log fields encrypt at the
  /// application layer in addition to the always-encrypted notes.
  sensitiveCategoryEncryption  Boolean @default(true) @map("sensitive_category_encryption")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("cycle_profiles")
}

/// One row per menstrual cycle (a period-start anchor + derived span).
/// `isPredicted` rows are forward-minted forecasts; observed rows are
/// confirmed from logged flow. Soft-deleted + syncVersion-bumped so the
/// row rides the `/api/sync/changes` feed as a tombstone.
model MenstrualCycle {
  id     String @id @default(cuid())
  userId String @map("user_id")

  /// YYYY-MM-DD — period start, anchored to `tz` when non-null, else the
  /// legacy Europe/Berlin assumption (the MoodEntry.date convention).
  startDate     String  @map("start_date")
  /// YYYY-MM-DD — cycle end (= day before the next cycle's start).
  endDate       String? @map("end_date")
  /// YYYY-MM-DD — last bleeding day of this cycle's period.
  periodEndDate String? @map("period_end_date")

  /// Observed cycle length in days (start→next start). NULL until the
  /// next cycle anchors it.
  lengthDays         Int?     @map("length_days")
  /// YYYY-MM-DD — confirmed or estimated ovulation day.
  ovulationDate      String?  @map("ovulation_date")
  /// True once ovulation is confirmed (symptothermal / temperature-trend),
  /// as opposed to a calendar estimate.
  ovulationConfirmed Boolean  @default(false) @map("ovulation_confirmed")
  /// Forward-minted forecast row vs an observed cycle.
  isPredicted        Boolean  @default(false) @map("is_predicted")

  /// Per-row IANA timezone the date strings are anchored to (NULL =
  /// legacy Europe/Berlin), mirroring MoodEntry.tz.
  tz          String?
  syncVersion Int       @default(0) @map("sync_version")
  deletedAt   DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayLogs CycleDayLog[]

  @@unique([userId, startDate])
  @@index([userId, startDate])
  // Keyset support for the `/api/sync/changes` cycle feed
  // (`where userId` ordered by `(updatedAt asc, id asc)`).
  @@index([userId, updatedAt, id])
  @@map("menstrual_cycles")
}

/// One canonical row per (user, day): the HealthKit sync unit + the
/// manual log-day surface. Dual-unique exactly like MoodEntry — the
/// canonical-day key plus the NULL-distinct external-dedup key for
/// HealthKit re-ingest. Soft-deleted + syncVersion-bumped.
model CycleDayLog {
  id     String  @id @default(cuid())
  userId String  @map("user_id")
  /// YYYY-MM-DD — anchored to `tz` when non-null, else legacy
  /// Europe/Berlin (the MoodEntry.date convention).
  date    String
  /// Optional link to the owning MenstrualCycle (set once the day is
  /// attributed to a cycle span).
  cycleId String? @map("cycle_id")

  /// Menstrual-flow intensity (NULL = not logged this day).
  flow                  FlowLevel?
  /// Spotting / bleeding outside the period window.
  intermenstrualBleeding Boolean   @default(false) @map("intermenstrual_bleeding")

  /// Basal body temperature in Celsius. Queryable-plaintext — feeds the
  /// symptothermal confirmation. BBT also lands in Measurement
  /// (BODY_TEMPERATURE) for charting; this column is the cycle-local copy.
  basalBodyTempC Float?         @map("basal_body_temp_c")
  /// Whether this day's BBT is a disturbed/unreliable reading (fever,
  /// illness, alcohol, a late or short-sleep measurement) the user marked
  /// excluded. When true the symptothermal engine drops the reading from the
  /// cover-line baseline AND the shift evaluation, so a spike neither
  /// fabricates nor masks a temperature rise (Sensiplan: the cover line is
  /// drawn over the last six *unbracketed* values).
  temperatureExcluded Boolean @default(false) @map("temperature_excluded")
  /// Ovulation predictor-kit (OPK) reading.
  ovulationTest  OvulationTest? @map("ovulation_test")
  /// Cervical-mucus quality.
  cervicalMucus  CervicalMucus? @map("cervical_mucus")

  /// Cervix observation — the three standard Sensiplan cervix signs, used
  /// as the symptothermal secondary indicator when
  /// CycleProfile.secondarySymptom is CERVIX. All NULL = not observed.
  /// The fertile combination is HIGH + SOFT + OPEN; the infertile
  /// (closure) combination is LOW + FIRM + CLOSED. Queryable-plaintext like
  /// the other physiology signs (mucus / BBT / OPK).
  cervixPosition CervixPosition? @map("cervix_position")
  cervixFirmness CervixFirmness? @map("cervix_firmness")
  cervixOpening  CervixOpening?  @map("cervix_opening")

  /// Intent-revealing fields. When CycleProfile.sensitiveCategoryEncryption
  /// is ON these are encrypted at the application layer (the dispatch
  /// envelope), default-ON for this category.
  sexualActivity Boolean            @default(false) @map("sexual_activity")
  protectedSex   Boolean?           @map("protected_sex")
  pregnancyTest    HomeTestResult?    @map("pregnancy_test")
  progesteroneTest HomeTestResult?    @map("progesterone_test")
  contraceptive    ContraceptiveKind? @map("contraceptive")

  /// AES-256-GCM ciphertext envelope of the intent-revealing fields
  /// (sexualActivity / protectedSex / pregnancyTest / progesteroneTest /
  /// contraceptive). Populated INSTEAD of the plaintext columns above when
  /// CycleProfile.sensitiveCategoryEncryption is ON: the plaintext columns
  /// are NULLed and this carries the JSON envelope, so the most sensitive
  /// reproductive data is encrypted at rest. Those five fields then drop
  /// out of the rollup / correlation tier (queryable plaintext is the
  /// trade for at-rest secrecy). Decrypted fail-soft on read.
  sensitiveEncrypted String? @map("sensitive_encrypted")

  /// AES-256-GCM ciphertext envelope of the day's free-text note (always
  /// encrypted — the `*Encrypted` String? convention, matching
  /// MoodTag.labelEncrypted + InsightNarrative).
  notesEncrypted String? @map("notes_encrypted")

  /// Provenance. MANUAL (web / single POST) or APPLE_HEALTH (the batch
  /// ingest); mirrors MoodEntry.source. The wire spelling is APPLE_HEALTH.
  source     MeasurementSource @default(MANUAL)
  /// Stable per-source dedup id. NULL for native / MANUAL entries (those
  /// dedup on the canonical `(userId, date)` key); a HealthKit re-ingest
  /// upserts on `(userId, source, externalId)`. Postgres treats NULLs as
  /// distinct so MANUAL rows never collide on it.
  externalId String?           @map("external_id")

  tz          String?
  syncVersion Int       @default(0) @map("sync_version")
  deletedAt   DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle        MenstrualCycle?    @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  symptomLinks CycleSymptomLink[]

  @@unique([userId, date])
  // NULL-distinct external dedup key for HealthKit re-ingest (the
  // MoodEntry dual-unique precedent).
  @@unique([userId, source, externalId])
  @@index([userId, date])
  // Keyset support for the `/api/sync/changes` cycle-day feed.
  @@index([userId, updatedAt, id])
  @@map("cycle_day_logs")
}

// ─── Cycle Symptom Taxonomy (v1.15.0) ─────────────────────────
//
// Clones the MoodTagCategory → MoodTag → MoodEntryTagLink trio: a global,
// icon-bearing, labelKey-i18n, isActive/sortOrder catalog plus a per-day
// join. `CycleSymptom` additionally carries `userId?` + `labelEncrypted?`
// so a future release can mint per-user custom symptoms (the MoodTag
// custom-tag precedent); v1.15.0 ships seeded-catalogue-only.

model CycleSymptomCategory {
  id        String  @id @default(cuid())
  /// Stable machine key (e.g. `physical`). Unique so the seed migration
  /// can upsert idempotently.
  key       String  @unique
  /// i18n message key for the category label (`cycle.symptomCategory.<key>`).
  labelKey  String  @map("label_key")
  /// Lucide icon name for the category header.
  icon      String?
  sortOrder Int     @default(0) @map("sort_order")
  /// Soft-hide a category without deleting its historical links.
  isActive  Boolean @default(true) @map("is_active")

  symptoms CycleSymptom[]

  @@map("cycle_symptom_categories")
}

model CycleSymptom {
  id         String  @id @default(cuid())
  categoryId String  @map("category_id")
  /// Stable machine key (e.g. `cramps`). Unique across the catalog.
  key        String  @unique
  /// i18n message key for the symptom label (`cycle.symptom.<key>`).
  labelKey   String  @map("label_key")
  /// Lucide icon name for the symptom chip.
  icon       String?
  sortOrder  Int     @default(0) @map("sort_order")
  isActive   Boolean @default(true) @map("is_active")

  /// Owner of a per-user custom symptom. NULL = the global seeded
  /// catalogue (resolves `labelKey` against the locale). Set = a user's
  /// own custom symptom carrying a `custom:<cuid>` key and a free-text
  /// label held in `labelEncrypted` (the MoodTag custom-tag precedent).
  userId         String? @map("user_id")
  /// AES-256-GCM ciphertext of a custom symptom's free-text label. NULL
  /// for catalogue rows. Decrypted server-side for the effective read.
  labelEncrypted String? @map("label_encrypted")

  category CycleSymptomCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  user     User?                @relation("UserCycleSymptoms", fields: [userId], references: [id], onDelete: Cascade)
  links    CycleSymptomLink[]

  @@index([categoryId, sortOrder])
  @@index([userId])
  @@map("cycle_symptoms")
}

/// Join: which symptoms a cycle day-log carries. Composite PK keeps the
/// pairing unique; cascade on both sides so deleting a day-log (or a
/// catalog symptom) cleans up its links.
model CycleSymptomLink {
  dayLogId  String   @map("day_log_id")
  symptomId String   @map("symptom_id")
  /// Optional 1-4 Likert intensity for this symptom on this day. NULL = a
  /// plain presence link (the pre-severity contract). Surfaced in
  /// CycleDayLogDTO so the log-day sheet can pre-fill the severity chips.
  severity  Int?     @map("severity")
  createdAt DateTime @default(now()) @map("created_at")

  dayLog  CycleDayLog  @relation(fields: [dayLogId], references: [id], onDelete: Cascade)
  symptom CycleSymptom @relation(fields: [symptomId], references: [id], onDelete: Cascade)

  @@id([dayLogId, symptomId])
  @@index([symptomId])
  @@map("cycle_symptom_links")
}

// ─── Illness / condition journal (v1.19.0) ────────────────────
//
// A CONDITION journal, not a flu log: any illness/condition kept for
// oneself, with a retrospective lens ("how did it announce itself?",
// what dropped, recovery time). Retrospective + correlated, NEVER a
// predictor/diagnoser. Born-gated by the module system (the gate is
// app-layer; there is no enable flag in the schema). The daily timeline
// mirrors the Cycle three-table shape (DayLog + Symptom catalog + Link).

/// One illness/condition episode. `lifecycle` distinguishes an acute
/// bout from an ongoing chronic condition, a recurring one, or a flare
/// hanging off a parent condition (`parentConditionId`). CHRONIC_ONGOING
/// has no "recovered" date and is excluded from the recovery-gap math.
model IllnessEpisode {
  id     String @id @default(cuid())
  userId String @map("user_id")
  /// User-facing label for the episode, e.g. "Erkältung", "Heuschnupfen".
  label  String
  /// Broad condition class. Widened beyond an infection log to cover the
  /// condition journal's scope.
  type      IllnessType
  /// Where this episode sits in its lifecycle. FLARE rows reference a
  /// parent condition via `parentConditionId`.
  lifecycle IllnessLifecycle @default(ACUTE)
  /// When the episode began (UTC instant; wall-clock anchoring is the
  /// reader's concern per the schema's UTC-only convention).
  onsetAt    DateTime  @map("onset_at")
  /// When the episode resolved. NULL = still ongoing. CHRONIC_ONGOING
  /// episodes stay NULL by design.
  resolvedAt DateTime? @map("resolved_at")
  /// Self-FK for flares: a FLARE/RECURRING bout hangs off the parent
  /// condition episode so the history threads under one condition.
  parentConditionId String? @map("parent_condition_id")
  /// Optional free-text note, AES-256-GCM encrypted at rest via
  /// `src/lib/crypto.ts` (Bytes column, `*Encrypted` suffix per
  /// convention).
  noteEncrypted Bytes? @map("note_encrypted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  /// Soft-delete tombstone. NULL = live; non-NULL = deleted at the instant.
  deletedAt DateTime? @map("deleted_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Parent condition for a flare/recurrence (self-relation).
  parent   IllnessEpisode?  @relation("IllnessFlares", fields: [parentConditionId], references: [id], onDelete: SetNull)
  flares   IllnessEpisode[] @relation("IllnessFlares")
  dayLogs  IllnessDayLog[]

  @@index([userId, deletedAt])
  @@index([userId, onsetAt])
  @@index([parentConditionId])
  @@map("illness_episodes")
}

/// One row per day of an illness episode (mirrors CycleDayLog): the
/// day's free-text note (encrypted), a coarse functional-impact slider,
/// an optional fever reading, plus the symptom links. Soft-deleted.
model IllnessDayLog {
  id        String @id @default(cuid())
  userId    String @map("user_id")
  episodeId String @map("episode_id")
  /// YYYY-MM-DD — anchored to `tz` when non-null, else legacy
  /// Europe/Berlin (the CycleDayLog / MoodEntry date convention).
  date String
  /// Coarse self-rated functional impact for the day (0 = no impact /
  /// fully functional … 3 = bedbound). NULL = not logged. A slider, not a
  /// symptom — kept on the day row like CycleDayLog's per-day signs.
  functionalImpact Int? @map("functional_impact")
  /// Optional body temperature for the day, in Celsius. Queryable
  /// plaintext (the CycleDayLog.basalBodyTempC precedent): the fever
  /// signal feeds the retrospective curve. NULL = not measured.
  feverC Float? @map("fever_c")
  /// AES-256-GCM ciphertext envelope of the day's free-text note (always
  /// encrypted — the `*Encrypted` Bytes convention).
  noteEncrypted Bytes? @map("note_encrypted")
  /// Optional timezone the `date` is anchored to (the CycleDayLog
  /// precedent).
  tz        String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  /// Soft-delete tombstone. NULL = live; non-NULL = deleted at the instant.
  deletedAt DateTime? @map("deleted_at")

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode      IllnessEpisode       @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  symptomLinks IllnessSymptomLink[]

  @@unique([episodeId, date])
  @@index([userId, date])
  @@index([episodeId])
  @@map("illness_day_logs")
}

/// Seeded catalog of illness symptoms (Jackson / WURSS-derived). Mirrors
/// CycleSymptom: a global, icon-bearing, labelKey-i18n, isActive/sortOrder
/// catalog joined per day. Severity is captured 0–3 on the link.
model IllnessSymptom {
  id        String  @id @default(cuid())
  /// Stable machine key (e.g. `cough`). Unique across the catalog so the
  /// seed migration can upsert idempotently.
  key       String  @unique
  /// i18n message key for the symptom label (`illness.symptom.<key>`).
  labelKey  String  @map("label_key")
  /// Lucide icon name for the symptom chip.
  icon      String?
  sortOrder Int     @default(0) @map("sort_order")
  /// Soft-hide a symptom without deleting its historical links.
  isActive  Boolean @default(true) @map("is_active")

  links IllnessSymptomLink[]

  @@index([sortOrder])
  @@map("illness_symptoms")
}

/// Join: which symptoms an illness day-log carries, with a 0–3 severity.
/// Composite PK keeps the pairing unique; cascade on both sides so
/// deleting a day-log (or a catalog symptom) cleans up its links.
model IllnessSymptomLink {
  dayLogId  String   @map("day_log_id")
  symptomId String   @map("symptom_id")
  /// 0–3 severity for this symptom on this day (the Jackson/WURSS scale:
  /// 0 = none, 1 = mild, 2 = moderate, 3 = severe). NULL = a plain
  /// presence link.
  severity  Int?     @map("severity")
  createdAt DateTime @default(now()) @map("created_at")

  dayLog  IllnessDayLog  @relation(fields: [dayLogId], references: [id], onDelete: Cascade)
  symptom IllnessSymptom @relation(fields: [symptomId], references: [id], onDelete: Cascade)

  @@id([dayLogId, symptomId])
  @@index([symptomId])
  @@map("illness_symptom_links")
}

/// One cached forecast per user, regenerated debounced /
/// stale-while-revalidate (the InsightNarrative + v1.8.7 assessment
/// cache pattern), NOT per-read. Derived — not soft-deleted.
model CyclePrediction {
  id     String @id @default(cuid())
  userId String @map("user_id")

  /// Which method produced this forecast.
  method PredictionMethod

  /// YYYY-MM-DD — predicted next period start (point estimate) plus the
  /// ranged Low / High band (rendered as a band, never a single date).
  nextPeriodStart     String  @map("next_period_start")
  nextPeriodStartLow  String  @map("next_period_start_low")
  nextPeriodStartHigh String  @map("next_period_start_high")

  /// YYYY-MM-DD — fertile-window bounds (goal-gated at the read surface).
  fertileWindowStart String? @map("fertile_window_start")
  fertileWindowEnd   String? @map("fertile_window_end")
  /// YYYY-MM-DD — predicted ovulation day.
  predictedOvulation String? @map("predicted_ovulation")

  /// 0..1 confidence, shrinking with cycle-length variance + sparse
  /// logging + < MIN_CYCLES observed.
  confidence     Float
  /// How many observed cycles the forecast was computed from.
  cyclesObserved Int      @map("cycles_observed")
  /// When the forecast was generated (drives the stale-while-revalidate
  /// debounce).
  generatedAt    DateTime @map("generated_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("cycle_predictions")
}
